# Supabase project URL and anon key -- safe to expose to the browser.
# Find these in: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key -- SERVER-SIDE ONLY. Never prefix with NEXT_PUBLIC_.
# This bypasses Row Level Security, so it must never be sent to the browser.
# Used only for the login_attempts rate-limiting table.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
